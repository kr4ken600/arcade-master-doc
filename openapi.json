                    "statusCode": {
                      "type": "number",
                      "example": 400
                    }
                  }
                }
              }
            }
          },
          "409": {
            "description": "Correo o usuario en uso",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Correo o nombre de usuario ya esta en uso"
                    },
                    "error": {
                      "type": "string",
                      "example": "Conflict"
                    },
                    "statusCode": {
                      "type": "number",
                      "example": 409
                    }
                  }
                }
              }
            }
