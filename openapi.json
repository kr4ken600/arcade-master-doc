{
  "openapi": "3.0.0",
  "info": {
    "title": "Arcade Master API",
    "description": "API para gestionar juegos arcade, salones, récords de sesiones y configuración de hardware.",
    "version": "1.0.0",
    "contact": {
      "name": "Soporte Arcade Master",
      "email": "respaldo.kr4ken@gmail.com"
    }
  },
  "servers": [
    {
      "url": "http://localhost:3001/api/v1/",
      "description": "Servidor de Desarrollo"
    }
  ],
  "tags": [
    {
      "name": "App",
      "description": "Rutas de estado de la aplicación"
    },
    {
      "name": "Auth",
      "description": "Autenticación y tokens"
    },
    {
      "name": "Users",
      "description": "Gestión de usuarios y administradores"
    },
    {
      "name": "Arcades",
      "description": "Gestión de salones arcade (negocios)"
    },
    {
      "name": "Games",
      "description": "Catálogo de videojuegos"
    },
    {
      "name": "Sessions",
      "description": "Registro de partidas, scores y uso de hardware"
    },
    {
      "name": "Invitations",
      "description": "Sistema de invitaciones"
    },
    {
      "name": "Webhooks",
      "description": "Integraciones a eventos externos"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "operationId": "AppController_getHello",
        "summary": "Healthcheck de la API",
        "description": "Verifica si el servicio base está en línea.",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Servicio en línea",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string",
                      "example": "Arcade Master API"
                    },
                    "status": {
                      "type": "string",
                      "example": "online"
                    },
                    "timestamp": {
                      "type": "string",
                      "format": "date-time",
                      "example": "2026-04-04T17:15:24.000Z"
                    },
                    "version": {
                      "type": "string",
                      "example": "1.0.0"
                    }
                  }
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "tags": [
          "App"
        ]
      }
    },
    "/auth/login": {
      "post": {
        "operationId": "AuthController_login",
        "summary": "Iniciar sesión",
        "description": "Autentica a un usuario y devuelve un JWT Bearer token.",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login exitoso. Devuelve el JWT.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "access_token": {
                      "type": "string",
                      "example": "YOUR_SECRET_TOKEN"
                    },
                    "user": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "number",
                          "example": 1
                        },
                        "username": {
                          "type": "string",
                          "example": "test"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Credenciales inválidas",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Credenciales inválidas"
                    },
                    "error": {
                      "type": "string",
                      "example": "Unauthorized"
                    },
                    "statusCode": {
                      "type": "number",
                      "example": 401
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "Auth"
        ]
      }
    },
