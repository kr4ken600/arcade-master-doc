{
  "openapi": "3.0.0",
  "info": {
    "title": "Arcade Master API",
    "description": "API para gestionar juegos arcade, salones, récords de sesiones y configuración de hardware.",
    "version": "1.0.0",
    "contact": {
      "name": "Soporte Arcade Master",
      "email": "soporte@arcademaster.api"
    }
  },
  "servers": [
    {
      "url": "http://localhost:3001/api/v1/",
      "description": "Servidor de Desarrollo"
    }
  ],
  "tags": [
    { "name": "App", "description": "Rutas de estado de la aplicación" },
    { "name": "Auth", "description": "Autenticación y tokens" },
    { "name": "Users", "description": "Gestión de usuarios y administradores" },
    { "name": "Arcades", "description": "Gestión de salones arcade (negocios)" },
    { "name": "Games", "description": "Catálogo de videojuegos" },
    { "name": "Sessions", "description": "Registro de partidas, scores y uso de hardware" },
    { "name": "Invitations", "description": "Sistema de invitaciones" },
    { "name": "Webhooks", "description": "Integraciones a eventos externos" }
  ],
  "paths": {
    "/": {
      "get": {
        "operationId": "AppController_getHello",
        "summary": "Healthcheck de la API",
        "description": "Verifica si el servicio base está en línea.",
        "parameters": [],
        "responses": {
          "200": { "description": "Servicio en línea" }
        },
        "tags": ["App"]
      }
    },
    "/auth/login": {
      "post": {
        "operationId": "AuthController_login",
        "summary": "Iniciar sesión",
        "description": "Autentica a un usuario y devuelve un JWT Bearer token.",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/LoginDto" }
            }
          }
        },
        "responses": {
          "200": { "description": "Login exitoso. Devuelve el JWT." },
          "401": { "description": "Credenciales inválidas" }
        },
        "tags": ["Auth"]
      }
    },
    "/games": {
      "post": {
        "operationId": "GamesController_create",
        "summary": "Crear un nuevo juego",
        "description": "Añade un nuevo título al catálogo global de la plataforma.",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateGameDto" }
            }
          }
        },
        "responses": {
          "201": { "description": "Juego creado exitosamente" },
          "400": { "description": "Datos de entrada inválidos" },
          "401": { "description": "No autorizado" }
        },
        "security": [{ "bearer": [] }],
        "tags": ["Games"]
      },
      "get": {
        "operationId": "GamesController_findAll",
        "summary": "Listar todos los juegos",
        "parameters": [],
        "responses": {
          "200": { "description": "Lista de juegos obtenida correctamente" },
          "401": { "description": "No autorizado" }
        },
        "security": [{ "bearer": [] }],
        "tags": ["Games"]
      }
    },
    "/games/{id}": {
      "get": {
        "operationId": "GamesController_findOne",
        "summary": "Obtener un juego por ID",
        "parameters": [
          { "name": "id", "required": true, "in": "path", "schema": { "type": "number" } }
        ],
        "responses": {
          "200": { "description": "Detalles del juego" },
          "404": { "description": "Juego no encontrado" }
        },
        "security": [{ "bearer": [] }],
        "tags": ["Games"]
      },
      "patch": {
        "operationId": "GamesController_update",
        "summary": "Actualizar un juego",
        "parameters": [
          { "name": "id", "required": true, "in": "path", "schema": { "type": "number" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateGameDto" }
            }
          }
        },
        "responses": {
          "200": { "description": "Juego actualizado exitosamente" },
          "404": { "description": "Juego no encontrado" }
        },
        "security": [{ "bearer": [] }],
        "tags": ["Games"]
      },
      "delete": {
        "operationId": "GamesController_remove",
        "summary": "Eliminar un juego",
        "parameters": [
          { "name": "id", "required": true, "in": "path", "schema": { "type": "number" } }
        ],
        "responses": {
          "204": { "description": "Juego eliminado" },
          "404": { "description": "Juego no encontrado" }
        },
        "security": [{ "bearer": [] }],
        "tags": ["Games"]
      }
    },
    "/games/{id}/image": {
      "post": {
        "operationId": "GamesController_uploadGameImage",
        "summary": "Subir imagen del juego",
        "parameters": [
          { "name": "id", "required": true, "in": "path", "schema": { "type": "number" } }
        ],
        "responses": {
          "201": { "description": "Imagen subida exitosamente" }
        },
        "security": [{ "bearer": [] }],
        "tags": ["Games"]
      }
    },
    "/sessions": {
      "post": {
        "operationId": "SessionsController_create",
        "summary": "Registrar nueva sesión",
        "description": "Guarda el registro de una partida jugada.",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateSessionDto" }
            }
          }
        },
        "responses": {
          "201": { "description": "Sesión registrada" }
        },
        "security": [{ "bearer": [] }],
        "tags": ["Sessions"]
      },
      "get": {
        "operationId": "SessionsController_findAll",
        "summary": "Listar sesiones",
        "parameters": [],
        "responses": {
          "200": { "description": "Historial de sesiones obtenido" }
        },
        "security": [{ "bearer": [] }],
        "tags": ["Sessions"]
      }
    },
    "/sessions/{id}": {
      "get": {
        "operationId": "SessionsController_findOne",
        "summary": "Obtener detalles de sesión",
        "parameters": [
          { "name": "id", "required": true, "in": "path", "schema": { "type": "number" } }
        ],
        "responses": {
          "200": { "description": "Detalles de la sesión" }
        },
        "security": [{ "bearer": [] }],
        "tags": ["Sessions"]
      },
      "patch": {
        "operationId": "SessionsController_update",
        "summary": "Actualizar sesión",
        "parameters": [
          { "name": "id", "required": true, "in": "path", "schema": { "type": "number" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateSessionDto" }
            }
          }
        },
        "responses": {
          "200": { "description": "Sesión actualizada" }
        },
        "security": [{ "bearer": [] }],
        "tags": ["Sessions"]
      },
      "delete": {
        "operationId": "SessionsController_remove",
        "summary": "Eliminar sesión",
        "parameters": [
          { "name": "id", "required": true, "in": "path", "schema": { "type": "number" } }
        ],
        "responses": {
          "200": { "description": "Sesión eliminada" }
        },
        "security": [{ "bearer": [] }],
        "tags": ["Sessions"]
      }
    },
    "/sessions/stats/most-played": {
      "get": {
        "operationId": "SessionsController_getMostPlayed",
        "summary": "Juegos más jugados",
        "parameters": [],
        "responses": {
          "200": { "description": "Estadísticas obtenidas" }
        },
        "security": [{ "bearer": [] }],
        "tags": ["Sessions"]
      }
    },
    "/sessions/stats/controllers": {
      "get": {
        "operationId": "SessionsController_getControllerStats",
        "summary": "Estadísticas de mandos",
        "parameters": [],
        "responses": {
          "200": { "description": "Uso de hardware obtenido" }
        },
        "security": [{ "bearer": [] }],
        "tags": ["Sessions"]
      }
    },
    "/sessions/game/{gameId}/highscores": {
      "get": {
        "operationId": "SessionsController_getHighScores",
        "summary": "Tabla de clasificación",
        "parameters": [
          { "name": "gameId", "required": true, "in": "path", "schema": { "type": "number" } }
        ],
        "responses": {
          "200": { "description": "Highscores obtenidos" }
        },
        "security": [{ "bearer": [] }],
        "tags": ["Sessions"]
      }
    },
    "/users": {
      "post": {
        "operationId": "UsersController_create",
        "summary": "Crear usuario",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateUserDto" }
            }
          }
        },
        "responses": {
          "201": { "description": "Usuario creado" }
        },
        "security": [{ "bearer": [] }],
        "tags": ["Users"]
      },
      "get": {
        "operationId": "UsersController_findAll",
        "summary": "Listar usuarios",
        "parameters": [],
        "responses": {
          "200": { "description": "Usuarios obtenidos" }
        },
        "security": [{ "bearer": [] }],
        "tags": ["Users"]
      }
    },
    "/users/register-owner": {
      "post": {
        "operationId": "UsersController_registerOwner",
        "summary": "Registrar propietario de Arcade",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RegisterOwnerDto" }
            }
          }
        },
        "responses": {
          "201": { "description": "Propietario registrado exitosamente" }
        },
        "security": [{ "bearer": [] }],
        "tags": ["Users"]
      }
    },
    "/users/{id}": {
      "get": {
        "operationId": "UsersController_findOne",
        "summary": "Obtener usuario",
        "parameters": [
          { "name": "id", "required": true, "in": "path", "schema": { "type": "number" } }
        ],
        "responses": {
          "200": { "description": "Detalles del usuario" }
        },
        "security": [{ "bearer": [] }],
        "tags": ["Users"]
      },
      "patch": {
        "operationId": "UsersController_update",
        "summary": "Actualizar usuario",
        "parameters": [
          { "name": "id", "required": true, "in": "path", "schema": { "type": "number" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateUserDto" }
            }
          }
        },
        "responses": {
          "200": { "description": "Usuario actualizado" }
        },
        "security": [{ "bearer": [] }],
        "tags": ["Users"]
      },
      "delete": {
        "operationId": "UsersController_remove",
        "summary": "Eliminar usuario",
        "parameters": [
          { "name": "id", "required": true, "in": "path", "schema": { "type": "number" } }
        ],
        "responses": {
          "200": { "description": "Usuario eliminado" }
        },
        "security": [{ "bearer": [] }],
        "tags": ["Users"]
      }
    },
    "/arcades": {
      "post": {
        "operationId": "ArcadesController_create",
        "summary": "Registrar salón Arcade",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateArcadeDto" }
            }
          }
        },
        "responses": {
          "201": { "description": "Salón registrado" }
        },
        "security": [{ "bearer": [] }],
        "tags": ["Arcades"]
      }
    },
    "/arcades/{name}": {
      "get": {
        "operationId": "ArcadesController_findOne",
        "summary": "Obtener salón por nombre",
        "parameters": [
          { "name": "name", "required": true, "in": "path", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Detalles del salón" },
          "404": { "description": "Salón no encontrado" }
        },
        "security": [{ "bearer": [] }],
        "tags": ["Arcades"]
      },
      "delete": {
        "operationId": "ArcadesController_remove",
        "summary": "Eliminar salón",
        "parameters": [
          { "name": "name", "required": true, "in": "path", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Salón eliminado" }
        },
        "security": [{ "bearer": [] }],
        "tags": ["Arcades"]
      }
    },
    "/webhooks": {
      "post": {
        "operationId": "WebhooksController_create",
        "summary": "Crear webhook",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateWebhookDto" }
            }
          }
        },
        "responses": {
          "201": { "description": "Webhook configurado" }
        },
        "security": [{ "bearer": [] }],
        "tags": ["Webhooks"]
      },
      "get": {
        "operationId": "WebhooksController_findAll",
        "summary": "Listar webhooks",
        "parameters": [],
        "responses": {
          "200": { "description": "Webhooks obtenidos" }
        },
        "security": [{ "bearer": [] }],
        "tags": ["Webhooks"]
      }
    },
    "/invitations": {
      "post": {
        "operationId": "InvitationsController_create",
        "summary": "Crear invitación",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateInvitationDto" }
            }
          }
        },
        "responses": {
          "201": { "description": "Invitación generada" }
        },
        "security": [{ "bearer": [] }],
        "tags": ["Invitations"]
      },
      "get": {
        "operationId": "InvitationsController_find",
        "summary": "Listar invitaciones",
        "parameters": [],
        "responses": {
          "200": { "description": "Invitaciones obtenidas" }
        },
        "security": [{ "bearer": [] }],
        "tags": ["Invitations"]
      }
    },
    "/invitations/{id}": {
      "patch": {
        "operationId": "InvitationsController_update",
        "summary": "Actualizar invitación",
        "parameters": [
          { "name": "id", "required": true, "in": "path", "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateInvitationDto" }
            }
          }
        },
        "responses": {
          "200": { "description": "Invitación modificada" }
        },
        "security": [{ "bearer": [] }],
        "tags": ["Invitations"]
      },
      "delete": {
        "operationId": "InvitationsController_remove",
        "summary": "Revocar invitación",
        "parameters": [
          { "name": "id", "required": true, "in": "path", "schema": { "type": "number" } }
        ],
        "responses": {
          "200": { "description": "Invitación revocada" }
        },
        "security": [{ "bearer": [] }],
        "tags": ["Invitations"]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http",
        "description": "Ingresa tu token JWT para autenticar las peticiones."
      }
    },
    "schemas": {
      "CreateGameDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "description": "El nombre del juego",
            "example": "The King of Fighters 2002 Magic Plus"
          },
          "genre": {
            "type": "string",
            "description": "Género del juego",
            "example": "Fighting"
          },
          "year": {
            "type": "number",
            "description": "Año de lanzamiento",
            "example": 2002
          }
        },
        "required": ["title", "genre", "year"]
      },
      "UpdateGameDto": {
        "type": "object",
        "properties": {
          "title": { "type": "string", "example": "The King of Fighters 2002 Magic Plus" },
          "genre": { "type": "string", "example": "Fighting" },
          "year": { "type": "number", "example": 2002 }
        }
      },
      "CreateSessionDto": {
        "type": "object",
        "properties": {
          "score": {
            "type": "number",
            "description": "Puntuación del juego",
            "example": 10123
          },
          "controllerUsed": {
            "type": "string",
            "description": "Mando usado para jugar",
            "example": "Custom Arcade Bluetooth/USB"
          },
          "gameId": {
            "type": "number",
            "description": "Id del juego",
            "example": 1
          }
        },
        "required": ["score", "controllerUsed", "gameId"]
      },
      "UpdateSessionDto": {
        "type": "object",
        "properties": {
          "score": { "type": "number", "example": 15000 },
          "controllerUsed": { "type": "string", "example": "Custom Arcade Bluetooth/USB" }
        }
      },
      "CreateUserDto": {
        "type": "object",
        "properties": {
          "email": { "type": "string", "example": "test@test.com" },
          "username": { "type": "string", "example": "ElManco" },
          "password": { "type": "string", "example": "p4ssw0rd!" },
          "invitationCode": { "type": "string", "example": "INV123" }
        },
        "required": ["email", "username", "password", "invitationCode"]
      },
      "RegisterOwnerDto": {
        "type": "object",
        "properties": {
          "email": { "type": "string", "example": "owner@arcademaster.com" },
          "username": { "type": "string", "example": "AdminArcade" },
          "password": { "type": "string", "example": "p4ssw0rd!" },
          "arcadeName": { "type": "string", "example": "Retro Central" }
        },
        "required": ["email", "username", "password", "arcadeName"]
      },
      "UpdateUserDto": {
        "type": "object",
        "properties": {
          "email": { "type": "string", "example": "test@test.com" },
          "username": { "type": "string", "example": "ElManco" },
          "password": { "type": "string", "example": "p4ssw0rd!" }
        }
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": { "type": "string", "example": "test@test.com" },
          "password": { "type": "string", "example": "p4ssw0rd!" }
        },
        "required": ["email", "password"]
      },
      "CreateArcadeDto": {
        "type": "object",
        "properties": {
          "businessName": { "type": "string", "example": "Arcade Master" },
          "subscriptionPlan": { "type": "string", "example": "premium" }
        },
        "required": ["businessName", "subscriptionPlan"]
      },
      "CreateWebhookDto": {
        "type": "object",
        "properties": {
          "url": { "type": "string", "example": "https://example.com/webhook" },
          "isActive": { "type": "boolean", "example": true }
        },
        "required": ["url", "isActive"]
      },
      "CreateInvitationDto": {
        "type": "object",
        "properties": {
          "arcadeId": { "type": "number", "example": 1, "description": "ID del salón" },
          "role": { "type": "string", "example": "player", "description": "Rol asignado" },
          "expiresAt": { "type": "string", "format": "date-time" }
        },
        "required": ["arcadeId", "role"]
      }
    }
  }
}